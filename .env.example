# ── GitHub App ──────────────────────────────────────────────────────────────
GITHUB_APP_ID=
# PEM private key. Either inline (with \n escapes or real newlines) or a file path.
GITHUB_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# ── LLM (default model, OpenAI-compatible) ──────────────────────────────────
# api: openai-completions | openai-responses | anthropic-messages | google-generative-ai ...
LLM_API=openai-completions
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=
LLM_MODEL=local-model
# Optional context window / max output for the default model (used by budget/truncation)
LLM_CONTEXT_WINDOW=128000
LLM_MAX_TOKENS=8192

# ── Per-phase model overrides (each falls back to the default model) ────────
# Format per var (any subset; missing fields inherit the default):
#   SUMMARY_MODEL / REVIEW_MODEL / CRITIQUE_MODEL / REPLY_MODEL
#   *_API / *_BASE_URL / *_API_KEY  (the var itself is the model id)
# SUMMARY_MODEL=
# REVIEW_MODEL=
# REPLY_MODEL=

# ── Behaviour ───────────────────────────────────────────────────────────────
OUTPUT_LANGUAGE=ko
MAX_INLINE_COMMENTS=20
MAX_LOOP_ITERATIONS=40
MAX_LOOP_TOKENS=400000
MAX_DIFF_TOKENS=60000
MAX_CONCURRENT_REVIEWS=1
JOB_TIMEOUT_MS=600000
DEBOUNCE_MS=30000
THINKING_LEVEL=medium

# Comma-separated branch globs / labels to exclude from auto-review
EXCLUDED_BRANCHES=
EXCLUDED_LABELS=no-review,wip

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
CHECKOUT_DIR=.checkout-cache
