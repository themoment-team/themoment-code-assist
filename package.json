{
  "name": "pr-review-bot",
  "version": "0.1.0",
  "description": "GitHub PR review bot — one-shot summary + single pi agent per PR (MVP: M0-M2)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "node --import tsx/esm --watch src/index.ts"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.79.1",
    "@earendil-works/pi-ai": "0.79.1",
    "@octokit/app": "^15.1.6",
    "@octokit/rest": "^21.1.0",
    "@octokit/webhooks": "^13.4.3",
    "fastify": "^5.2.1",
    "p-queue": "^8.1.0",
    "parse-diff": "^0.11.1",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
